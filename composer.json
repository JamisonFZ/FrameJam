{
    "name": "framejam/framework",
    "description": "Um framework PHP moderno e elegante",
    "type": "project",
    "require": {
        "php": "^8.1",
        "symfony/http-foundation": "^6.0",
        "symfony/routing": "^6.0",
        "symfony/console": "^6.0",
        "monolog/monolog": "^3.0",
        "predis/predis": "^2.0",
        "symfony/mailer": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "FrameJam\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FrameJam\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf"
    },
    "config": {
        "sort-packages": true
    },
    "authors": [
        {
            "name": "FrameJam Team",
            "email": "contact@framejam.com"
        }
    ],
    "minimum-stability": "stable"
} 